pipeline {
  agent {
    kubernetes {
      yamlFile 'jenkins/Jenkins-agent.yaml'
      defaultContainer 'kubectl'
    }
  }

  parameters {
    string(
      name: 'API_IMAGE_TAG',
      defaultValue: 'latest',
      description: 'API image tag to deploy (e.g. Jenkins build number from api-ci)'
    )
    string(
      name: 'CLIENT_IMAGE_TAG',
      defaultValue: 'latest1',
      description: 'Client image tag (leave as latest1 unless client-ci ran too)'
    )
  }

  stages {

    stage('Stage 1: Checkout') {
      steps {
        echo "Checking out code..."
        git branch: 'main', url: 'https://github.com/amitactive2008/DevSecOps-Mega-Project.git'
      }
    }

    stage('Stage 2: Update Image Tags') {
      steps {
        echo "Patching kustomization.yaml with new image tags..."
        sh '''
          # Replace API image tag (sed: find 'name: amitactive2008/api', then replace next 'newTag:' line)
          sed -i '/name: amitactive2008\\/api/{n; s/newTag: .*/newTag: '"${API_IMAGE_TAG}"'/}' \
            kubernetes/overlays/local/kustomization.yaml

          # Replace Client image tag
          sed -i '/name: amitactive2008\\/client/{n; s/newTag: .*/newTag: '"${CLIENT_IMAGE_TAG}"'/}' \
            kubernetes/overlays/local/kustomization.yaml

          echo "=== Updated image tags ==="
          grep -A1 "name: amitactive2008" kubernetes/overlays/local/kustomization.yaml | grep -v "^--$"
        '''
      }
    }

    stage('Stage 3: Deploy') {
      steps {
        echo "Deploying to local Kind cluster (namespace: local)..."
        sh '''
          # Migration job is immutable — must delete before re-apply
          kubectl delete job database-migration -n local --ignore-not-found

          # Apply the full local overlay
          kubectl apply -k kubernetes/overlays/local
        '''
      }
    }

    stage('Stage 4: Verify Rollout') {
      steps {
        echo "Waiting for rollout to complete..."
        sh '''
          kubectl rollout status deployment/api-deployment    -n local --timeout=5m
          kubectl rollout status deployment/client-deployment -n local --timeout=5m

          echo ""
          echo "=== Deployed Pods ==="
          kubectl get pods -n local

          echo ""
          echo "=== API Health Check ==="
          POD=$(kubectl get pod -l app.kubernetes.io/name=api -n local \
                  -o jsonpath="{.items[0].metadata.name}")
          kubectl exec -n local "$POD" -- wget -qO- http://localhost:5000/health
          echo ""
          kubectl exec -n local "$POD" -- wget -qO- http://localhost:5000/live
        '''
      }
    }

  }

  post {
    success {
      echo "Deployed amitactive2008/api:${params.API_IMAGE_TAG} to local Kind cluster ✓"
    }
    failure {
      echo "Deployment failed. Check: kubectl get pods -n local && kubectl describe pod -n local <pod>"
    }
  }
}
